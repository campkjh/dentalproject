# Supabase ------------------------------------------------------------------
# Get these from your Supabase project: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (do NOT expose to the browser). Used for seed scripts and admin tasks.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL used in OAuth redirect callbacks (e.g. https://kidoctor.app or http://localhost:3000)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Naver Maps (NCP) — 지도 표시 + 주소→좌표 변환
# Client ID는 공개값(지도 스크립트 ncpKeyId), Secret은 서버 전용(Geocoding)
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=
NAVER_MAP_CLIENT_SECRET=

# Public company/legal display values -------------------------------------------------
NEXT_PUBLIC_COMPANY_NAME=(주)키닥터
NEXT_PUBLIC_COMPANY_REPRESENTATIVE=
NEXT_PUBLIC_COMPANY_BUSINESS_NUMBER=
NEXT_PUBLIC_COMPANY_MAIL_ORDER_NUMBER=
NEXT_PUBLIC_COMPANY_POSTAL_CODE=
NEXT_PUBLIC_COMPANY_ADDRESS=서울특별시 금천구 가산디지털1로 225, 11층 1123-에이-2호
NEXT_PUBLIC_COMPANY_PHONE=
NEXT_PUBLIC_COMPANY_EMAIL=
NEXT_PUBLIC_COPYRIGHT_NAME=키닥터
